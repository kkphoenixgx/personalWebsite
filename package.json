{
  "name": "personal-website",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "host": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "pipeline": "node scripts/log-start.js && npm run audit:ci && npm run test:ci && node scripts/log-static-analysis.js && npm run build:ci && node scripts/log-lighthouse.js && npm run e2e && node scripts/log-end.js",
    "pipeline:full": "node scripts/log-start.js && npm run audit:ci && npm run test:ci && node scripts/log-static-analysis.js && npm run build:ci && node scripts/log-lighthouse.js && npm run e2e && npm run mutate && node scripts/log-stryker.js && node scripts/log-end.js",
    "mutate": "rimraf .stryker-tmp && npx @stryker-mutator/core run",
    "mutate:ci": "node scripts/log-start.js && npm run mutate && node scripts/log-stryker.js && node scripts/log-end.js",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadlessCI --code-coverage",
    "build:ci": "ng build --configuration production",
    "audit:ci": "npm audit --audit-level=high || echo \"\n⚠️ [Aviso] Vulnerabilidades encontradas, mas continuando o pipeline localmente...\n\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/material": "^19.1.5",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@angular/ssr": "^19.1.7",
    "@fontsource/roboto": "^5.1.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "gsap": "^3.12.7",
    "material-icons": "^1.13.14",
    "matter-js": "^0.20.0",
    "pdfjs-dist": "^5.6.205",
    "poly-decomp": "^0.3.0",
    "rxjs": "~7.8.0",
    "svg-path-to-polygons": "^0.1.0",
    "three": "^0.173.0",
    "tslib": "^2.8.1",
    "vanta": "^0.5.24",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.7",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^19.1.7",
    "@angular/compiler-cli": "^19.2.21",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/karma-runner": "^9.6.1",
    "@types/gsap": "^1.20.2",
    "@types/jasmine": "~5.1.0",
    "@types/matter-js": "^0.19.8",
    "@types/node": "^25.6.0",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/three": "^0.173.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "ajv": "^8.17.1",
    "axe-core": "^4.9.1",
    "eslint": "^8.57.1",
    "http-server": "^14.1.1",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-json-reporter": "^1.2.0",
    "lighthouse": "^13.1.0",
    "typescript": "~5.7.2"
  }
}
